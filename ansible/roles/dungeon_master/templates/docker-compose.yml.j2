services:
  dungeon-master-backend:
    image: {{ dungeon_master_image }}
    container_name: dungeon-master-backend
    restart: unless-stopped
    environment:
      GROQ_API_KEY: "{{ vault_groq_api_key }}"
      DM_MODEL: llama-3.3-70b-versatile
      DATABASE_URL: "postgresql://dm_app:{{ vault_dm_db_password }}@supabase-db:5432/postgres"
      SUPABASE_URL: "https://{{ supabase_api_domain }}"
      SUPABASE_ANON_KEY: "{{ vault_anon_key }}"
      SUPABASE_SERVICE_ROLE_KEY: "{{ vault_service_role_key }}"
      EMBEDDING_MODEL: sentence-transformers/all-MiniLM-L6-v2
      CORS_ORIGINS: https://dm.jimr.fyi
      PORT: "8080"
    networks:
      - supabase_default
      - supabase_frontend
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/healthz"]
      interval: 30s
      timeout: 5s
      retries: 3
    mem_limit: 768m

networks:
  supabase_default:
    external: true
    name: docker_default
  supabase_frontend:
    external: true
    name: docker_frontend
