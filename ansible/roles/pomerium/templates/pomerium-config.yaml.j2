# Pomerium config — all-in-one mode, single binary serves authenticate + proxy.
# Templated by ansible/roles/pomerium/tasks/main.yml. Do not edit on the host.

authenticate_service_url: https://{{ authenticate_domain }}

cookie_secret: {{ vault_pomerium_cookie_secret }}
shared_secret: {{ vault_pomerium_shared_secret }}

# Single cookie shared across all *.jimr.fyi routes — one sign-in covers all.
# practice.exchange is a different apex; cross-domain SSO falls back to
# Pomerium's signed-query-param session share (works without shared cookies).
cookie_domain: jimr.fyi

# Postgres-backed databroker keeps sessions across Pomerium restarts.
# In-memory default loses everyone on every container restart.
databroker_storage_type: postgres
databroker_storage_connection_string: postgres://pomerium_db:{{ vault_pomerium_db_password }}@db:5432/pomerium?sslmode=disable

# Baseline security response headers applied to every route.
set_response_headers:
  Strict-Transport-Security: "max-age=31536000; includeSubDomains; preload"
  X-Content-Type-Options: "nosniff"
  X-Frame-Options: "SAMEORIGIN"
  Referrer-Policy: "strict-origin-when-cross-origin"

# OIDC against GoTrue. Three values must agree on the issuer string:
# idp_provider_url, the discovery doc's `issuer`, and GoTrue's minted-token
# `iss`. GoTrue mints iss=https://api.jimr.fyi/auth/v1, so Pomerium uses the
# public URL too. Pomerium loopback-fetches the discovery doc through its
# own route on api.jimr.fyi (which proxies to static-jimr's corrected JSON,
# fixing GoTrue v2.186's broken empty-issuer discovery).
idp_provider: oidc
idp_provider_url: https://{{ supabase_api_domain }}/auth/v1
idp_client_id: {{ vault_pomerium_idp_client_id }}
idp_client_secret: {{ vault_pomerium_idp_client_secret }}
idp_scopes:
  - openid
  - email
  - profile

# Static Cloudflare Origin Certificate for *.jimr.fyi + jimr.fyi.
# Pomerium's autocert can't traverse Cloudflare's edge proxy (CF strips the
# acme-tls/1 ALPN extension; Pomerium doesn't fall back to HTTP-01). The
# Origin Cert is trusted by Cloudflare's edge servers (NOT by browsers — CF
# terminates TLS to clients with its own edge cert). Cert covers *.jimr.fyi
# only; practice.exchange runs in a separate CF zone and needs its own cert
# block (or its route dropped) when that tenant's origin cert is provisioned.
certificates:
  - cert: /pomerium/certs/origin.crt
    key: /pomerium/certs/origin.key
  # practice.exchange runs in a separate CF zone; its own Origin Cert
  # (SAN: *.practice.exchange, practice.exchange). Pomerium picks the
  # right cert per SNI match.
  - cert: /pomerium/certs/exchange.crt
    key: /pomerium/certs/exchange.key

# Header forwarding defaults — per-route overrides below where needed.
jwt_claims_headers:
  - email
  - sub

routes:
  # ---- API / Supabase ----
  # Specific path FIRST: corrected OIDC discovery JSON for api.jimr.fyi.
  - from: https://{{ supabase_api_domain }}
    prefix: /auth/v1/.well-known/openid-configuration
    to: http://static-jimr
    prefix_rewrite: /openid-configuration
    allow_public_unauthenticated_access: true
    preserve_host_header: false

  # Everything else on api.jimr.fyi → Kong (rest, auth, realtime, storage, functions).
  - from: https://{{ supabase_api_domain }}
    to: http://kong:8000
    allow_public_unauthenticated_access: true
    preserve_host_header: true
    allow_websockets: true

  # ---- Auth portal ----
  # /auth/v1/* hits GoTrue via Kong (recovery email links + OAuth Server endpoints
  # resolve at the same host as SITE_URL).
  - from: https://{{ auth_domain }}
    prefix: /auth/v1/
    to: http://kong:8000
    allow_public_unauthenticated_access: true
    preserve_host_header: true

  # Static portal SPA at the root. prefix_rewrite needs the trailing slash
  # so Envoy turns /foo into /portal/foo, not /portalfoo.
  - from: https://{{ auth_domain }}
    to: http://static-jimr
    prefix_rewrite: /portal/
    allow_public_unauthenticated_access: true

  # ---- dm static client (public; auth happens client-side via GoTrue) ----
  - from: https://dm.jimr.fyi
    to: http://static-jimr
    prefix_rewrite: /dm/
    allow_public_unauthenticated_access: true

  # ---- Tenant frontends (public-at-gateway; Phase 2 will gate per-tenant) ----
{% for tenant in tenants if tenant.name != 'dungeon-master' %}
  - from: https://{{ tenant.domain }}
    to: http://frontend-{{ tenant.name }}:80
    allow_public_unauthenticated_access: true
{% endfor %}

  # ---- Gated routes (jimjrasche@gmail.com only) ----
  - from: https://{{ gitea_domain }}
    to: http://gitea:3000
    pass_identity_headers: true
    policy:
      - allow:
          and:
            - email:
                is: jimjrasche@gmail.com

  - from: https://{{ supabase_studio_domain }}
    to: http://studio:3000
    pass_identity_headers: true
    policy:
      - allow:
          and:
            - email:
                is: jimjrasche@gmail.com

  - from: https://{{ monitoring_domain }}
    to: http://gatus:8080
    policy:
      - allow:
          and:
            - email:
                is: jimjrasche@gmail.com

  # apps.jimr.fyi served by static-jimr's autoindex (replaces Caddy file_server browse).
  - from: https://{{ app_distribution_domain }}
    to: http://static-jimr
    prefix_rewrite: /apps/
    policy:
      - allow:
          and:
            - email:
                is: jimjrasche@gmail.com
