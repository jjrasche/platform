{
    servers {
        trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/24 188.114.97.0/24 188.114.98.0/24 188.114.99.0/24 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
        client_ip_headers CF-Connecting-IP
    }
}

{% for tenant in tenants if tenant.name != 'dungeon-master' %}
{{ tenant.domain }} {
    reverse_proxy frontend-{{ tenant.name }}:80
}

{% endfor %}
dm.jimr.fyi {
    encode zstd gzip

    handle {
        root * /var/www/dungeon-master
        # auth-bootstrap.js and config.js are auth-critical — a stale cached
        # copy after a flow-type or anon-key change locks users into a
        # redirect loop. Force revalidation on every load.
        header /auth-bootstrap.js Cache-Control "no-cache, must-revalidate"
        header /config.js Cache-Control "no-cache, must-revalidate"
        try_files {path} /index.html
        file_server
    }

    log {
        output file /var/log/caddy/dm.jimr.fyi.log
        format json
    }
}


{{ app_distribution_domain }} {
    root * /opt/app-dist
    @apk path *.apk
    header @apk Content-Type application/vnd.android.package-archive
    file_server browse
}
{{ monitoring_domain }} {
    reverse_proxy gatus:8080
}
{{ auth_domain }} {
    # /auth/v1/* hits GoTrue (via Kong) so recovery email links and the
    # OAuth Server endpoints resolve at the same host as SITE_URL.
    handle /auth/v1/* {
        reverse_proxy kong:8000
    }

    handle {
        root * /opt/auth-portal
        # Apply no-cache to ALL portal assets, not just the index.html
        # try_files response. Caddy's `header` directive at the block level
        # is overridden by file_server's defaults (max-age=14400) for files
        # it serves; this ordering forces no-cache to win.
        header * Cache-Control "no-cache, must-revalidate"
        try_files {path} /index.html
        file_server
    }
}
{{ supabase_api_domain }} {
    # OIDC discovery doc — GoTrue v2.186 returns relative URLs and an empty
    # issuer, which breaks any OIDC client (Gitea, Grafana, etc.). Serve a
    # corrected doc here and let everything else fall through to Kong.
    handle /auth/v1/.well-known/openid-configuration {
        header Content-Type application/json
        respond `{"issuer":"https://{{ supabase_api_domain }}/auth/v1","authorization_endpoint":"https://{{ supabase_api_domain }}/auth/v1/oauth/authorize","token_endpoint":"https://{{ supabase_api_domain }}/auth/v1/oauth/token","jwks_uri":"https://{{ supabase_api_domain }}/auth/v1/.well-known/jwks.json","userinfo_endpoint":"https://{{ supabase_api_domain }}/auth/v1/oauth/userinfo","scopes_supported":["openid","profile","email"],"response_types_supported":["code"],"response_modes_supported":["query"],"grant_types_supported":["authorization_code","refresh_token"],"subject_types_supported":["public"],"id_token_signing_alg_values_supported":["ES256"],"token_endpoint_auth_methods_supported":["client_secret_post","client_secret_basic"],"claims_supported":["sub","aud","iss","exp","iat","email","email_verified","name"],"code_challenge_methods_supported":["S256"]}` 200
    }

    handle /rest/v1/* {
        reverse_proxy kong:8000
    }

    handle /auth/v1/* {
        reverse_proxy kong:8000
    }

    handle /realtime/v1/* {
        reverse_proxy kong:8000
    }

    handle /storage/v1/* {
        reverse_proxy kong:8000
    }

    handle /functions/v1/* {
        reverse_proxy kong:8000
    }
}

{{ gitea_domain }} {
    reverse_proxy gitea:3000
}

{{ supabase_studio_domain }} {
    basic_auth {
        {{ vault_studio_user }} {{ vault_studio_password_hash }}
    }
    reverse_proxy studio:3000
}
