services:
{% for tenant in tenants %}
  frontend-{{ tenant.name }}:
    image: ghcr.io/jjrasche/{{ tenant.repo }}:latest
    restart: unless-stopped
    networks:
      - default

{% endfor %}
  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./volumes/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    depends_on:
      - kong
{% for tenant in tenants %}
      - frontend-{{ tenant.name }}
{% endfor %}
    networks:
      - default

  kong:
    ports: !reset []

  studio:
    depends_on: !override
      db:
        condition: service_healthy

  storage:
    depends_on: !override
      db:
        condition: service_healthy
      rest:
        condition: service_started

  analytics:
    profiles:
      - disabled

  vector:
    profiles:
      - disabled

  imgproxy:
    profiles:
      - disabled

volumes:
  caddy_data:
  caddy_config:
