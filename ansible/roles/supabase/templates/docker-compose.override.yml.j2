services:
{% for tenant in tenants %}
  frontend-{{ tenant.name }}:
    image: ghcr.io/jjrasche/{{ tenant.repo }}:latest
    restart: unless-stopped
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp
      - /var/cache/caddy
      - /var/run
    networks:
      - frontend

{% endfor %}
  gatus:
    image: twinproduction/gatus:latest
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    volumes:
      - /opt/gatus/config.yaml:/config/config.yaml:ro
      - gatus_data:/data
    networks:
      - frontend

  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./volumes/caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
      - /opt/app-dist:/opt/app-dist:ro
      - /opt/auth-portal:/opt/auth-portal:ro
    depends_on:
      - kong
      - gatus
{% for tenant in tenants %}
      - frontend-{{ tenant.name }}
{% endfor %}
    networks:
      - frontend
      - default

  studio:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  kong:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    tmpfs:
      - /tmp
    ports: !reset []

  auth:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      GOTRUE_SMS_PROVIDER: ${GOTRUE_SMS_PROVIDER}
      GOTRUE_SMS_TWILIO_VERIFY_ACCOUNT_SID: ${GOTRUE_SMS_TWILIO_VERIFY_ACCOUNT_SID}
      GOTRUE_SMS_TWILIO_VERIFY_AUTH_TOKEN: ${GOTRUE_SMS_TWILIO_VERIFY_AUTH_TOKEN}
      GOTRUE_SMS_TWILIO_VERIFY_MESSAGE_SERVICE_SID: ${GOTRUE_SMS_TWILIO_VERIFY_MESSAGE_SERVICE_SID}
      # Social providers
      GOTRUE_EXTERNAL_GOOGLE_ENABLED: ${GOTRUE_EXTERNAL_GOOGLE_ENABLED:-false}
      GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID: ${GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID:-}
      GOTRUE_EXTERNAL_GOOGLE_SECRET: ${GOTRUE_EXTERNAL_GOOGLE_SECRET:-}
      GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI: ${GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI:-}
      GOTRUE_EXTERNAL_GITHUB_ENABLED: ${GOTRUE_EXTERNAL_GITHUB_ENABLED:-false}
      GOTRUE_EXTERNAL_GITHUB_CLIENT_ID: ${GOTRUE_EXTERNAL_GITHUB_CLIENT_ID:-}
      GOTRUE_EXTERNAL_GITHUB_SECRET: ${GOTRUE_EXTERNAL_GITHUB_SECRET:-}
      GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI: ${GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI:-}
      # Asymmetric JWT signing
      GOTRUE_JWT_KEYS: ${GOTRUE_JWT_KEYS:-}
      GOTRUE_JWT_VALID_METHODS: ${GOTRUE_JWT_VALID_METHODS:-HS256}
      # OAuth 2.1 Server
      GOTRUE_OAUTH_SERVER_ENABLED: ${GOTRUE_OAUTH_SERVER_ENABLED:-false}
      GOTRUE_OAUTH_SERVER_AUTHORIZATION_PATH: ${GOTRUE_OAUTH_SERVER_AUTHORIZATION_PATH:-}
      GOTRUE_OAUTH_SERVER_AUTHORIZATION_TTL: ${GOTRUE_OAUTH_SERVER_AUTHORIZATION_TTL:-10m}
      GOTRUE_OAUTH_SERVER_DEFAULT_SCOPE: ${GOTRUE_OAUTH_SERVER_DEFAULT_SCOPE:-openid email}
      GOTRUE_OAUTH_SERVER_ALLOW_DYNAMIC_REGISTRATION: ${GOTRUE_OAUTH_SERVER_ALLOW_DYNAMIC_REGISTRATION:-false}

  rest:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  realtime:
    cap_drop:
      - ALL
    cap_add:
      - SETUID
      - SETGID
    read_only: true
    tmpfs:
      - /tmp

  storage:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  imgproxy:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  meta:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  functions:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  analytics:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  vector:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - DAC_READ_SEARCH
    read_only: true
    tmpfs:
      - /tmp
      - /var/lib/vector

  db:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - FOWNER
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    read_only: true
    tmpfs:
      - /tmp
      - /var/run/postgresql
    ports: !reset
      - "127.0.0.1:5432:5432"

  supavisor:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    ports: !reset
      - "127.0.0.1:6543:6543"

networks:
  frontend:

volumes:
  caddy_data:
  caddy_config:
  gatus_data:
