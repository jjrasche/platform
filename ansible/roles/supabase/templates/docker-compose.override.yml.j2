services:
{% for tenant in tenants if tenant.name != 'dungeon-master' %}
  frontend-{{ tenant.name }}:
    image: ghcr.io/jjrasche/{{ tenant.repo }}:latest
    restart: unless-stopped
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    read_only: true
    tmpfs:
      - /tmp
      - /var/cache/caddy
      - /var/run
    networks:
      - frontend

{% endfor %}
  gitea:
    image: gitea/gitea:1.25.2
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    environment:
      GITEA__server__DOMAIN: "{{ gitea_domain }}"
      GITEA__server__ROOT_URL: "https://{{ gitea_domain }}"
      GITEA__server__HTTP_PORT: "3000"
      GITEA__server__DISABLE_SSH: "true"
      GITEA__database__DB_TYPE: "sqlite3"
      GITEA__database__PATH: "/data/gitea/gitea.db"
      GITEA__security__INSTALL_LOCK: "true"
      GITEA__security__SECRET_KEY: "{{ vault_gitea_secret_key }}"
      GITEA__service__DISABLE_REGISTRATION: "true"
      # Pomerium is the only path to Gitea — trust the X-Pomerium-Claim-Email
      # header (set by `pass_identity_headers: true` on the route). Auto-
      # registration creates a Gitea user on first login keyed off the
      # Pomerium-asserted email.
      GITEA__service__ENABLE_REVERSE_PROXY_AUTHENTICATION: "true"
      GITEA__service__ENABLE_REVERSE_PROXY_AUTO_REGISTRATION: "true"
      GITEA__service__ENABLE_REVERSE_PROXY_EMAIL: "true"
      # Gitea's Verify() tries AUTH_USER (header → username lookup) first,
      # then falls back to AUTH_EMAIL (header → email lookup). Pomerium's
      # X-Pomerium-Claim-Email carries the email; user "jim" has that
      # email, so the email lookup matches.
      #
      # Note: the INI keys are REVERSE_PROXY_AUTHENTICATION_USER and
      # REVERSE_PROXY_AUTHENTICATION_EMAIL, not _HEADER/_EMAIL_HEADER like
      # some docs imply (see gotrue modules/setting/security.go).
      GITEA__security__REVERSE_PROXY_AUTHENTICATION_USER: "X-Pomerium-Claim-Email"
      GITEA__security__REVERSE_PROXY_AUTHENTICATION_EMAIL: "X-Pomerium-Claim-Email"
      GITEA__security__REVERSE_PROXY_TRUSTED_PROXIES: "172.16.0.0/12"
    volumes:
      - gitea_data:/data
    networks:
      - frontend

  gatus:
    image: twinproduction/gatus:latest
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    volumes:
      - /opt/gatus/config.yaml:/config/config.yaml:ro
      - gatus_data:/data
    networks:
      - frontend

  pomerium:
    # Outbound PKCE landed in main (PR #6061) but no v0.32.x release contains
    # it — that branch was cut before the merge. SHA-pinned main image until
    # the next minor release ships PKCE.
    image: pomerium/pomerium:git-c84949b5
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./volumes/pomerium/config.yaml:/pomerium/config.yaml:ro
      - ./volumes/pomerium/certs:/pomerium/certs:ro
      - pomerium_data:/data
    depends_on:
      - kong
      - gitea
      - gatus
      - studio
      - static-jimr
{% for tenant in tenants if tenant.name != 'dungeon-master' %}
      - frontend-{{ tenant.name }}
{% endfor %}
    networks:
      - frontend
      - default

  static-jimr:
    image: nginx:1.29-alpine
    restart: unless-stopped
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETUID
      - SETGID
    read_only: true
    tmpfs:
      - /tmp
      - /var/cache/nginx
      - /var/run
    volumes:
      - ./volumes/static-jimr/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./volumes/static-jimr/oidc:/srv/oidc:ro
      - /var/www/dungeon-master:/srv/dm:ro
      - /opt/auth-portal:/srv/portal:ro
      - /opt/app-dist:/srv/apps:ro
    networks:
      - frontend

  studio:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  kong:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    tmpfs:
      - /tmp
    ports: !reset []

  auth:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      GOTRUE_SMS_PROVIDER: ${GOTRUE_SMS_PROVIDER}
      GOTRUE_SMS_TWILIO_VERIFY_ACCOUNT_SID: ${GOTRUE_SMS_TWILIO_VERIFY_ACCOUNT_SID}
      GOTRUE_SMS_TWILIO_VERIFY_AUTH_TOKEN: ${GOTRUE_SMS_TWILIO_VERIFY_AUTH_TOKEN}
      GOTRUE_SMS_TWILIO_VERIFY_MESSAGE_SERVICE_SID: ${GOTRUE_SMS_TWILIO_VERIFY_MESSAGE_SERVICE_SID}
      # Social providers
      GOTRUE_EXTERNAL_GOOGLE_ENABLED: ${GOTRUE_EXTERNAL_GOOGLE_ENABLED:-false}
      GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID: ${GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID:-}
      GOTRUE_EXTERNAL_GOOGLE_SECRET: ${GOTRUE_EXTERNAL_GOOGLE_SECRET:-}
      GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI: ${GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI:-}
      GOTRUE_EXTERNAL_GITHUB_ENABLED: ${GOTRUE_EXTERNAL_GITHUB_ENABLED:-false}
      GOTRUE_EXTERNAL_GITHUB_CLIENT_ID: ${GOTRUE_EXTERNAL_GITHUB_CLIENT_ID:-}
      GOTRUE_EXTERNAL_GITHUB_SECRET: ${GOTRUE_EXTERNAL_GITHUB_SECRET:-}
      GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI: ${GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI:-}
{% if oauth_server_enabled %}
      GOTRUE_OAUTH_SERVER_ENABLED: ${GOTRUE_OAUTH_SERVER_ENABLED}
      GOTRUE_OAUTH_SERVER_AUTHORIZATION_PATH: ${GOTRUE_OAUTH_SERVER_AUTHORIZATION_PATH}
      GOTRUE_OAUTH_SERVER_AUTHORIZATION_TTL: ${GOTRUE_OAUTH_SERVER_AUTHORIZATION_TTL}
      GOTRUE_OAUTH_SERVER_DEFAULT_SCOPE: ${GOTRUE_OAUTH_SERVER_DEFAULT_SCOPE}
      GOTRUE_OAUTH_SERVER_ALLOW_DYNAMIC_REGISTRATION: ${GOTRUE_OAUTH_SERVER_ALLOW_DYNAMIC_REGISTRATION}
{% if vault_gotrue_jwt_keys is defined %}
      # ES256 signing — only when asymmetric keys are provisioned. GoTrue rejects
      # empty GOTRUE_JWT_KEYS at boot, so this block must be absent when unset.
      GOTRUE_JWT_KEYS: ${GOTRUE_JWT_KEYS}
      GOTRUE_JWT_VALID_METHODS: ${GOTRUE_JWT_VALID_METHODS}
      # OAuth ID token iss claim — upstream supabase compose doesn't pass
      # this from .env, so it gets injected here.
      GOTRUE_JWT_ISSUER: ${GOTRUE_JWT_ISSUER}
{% endif %}
{% endif %}

  rest:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
{% if oauth_server_enabled and vault_jwt_jwks is defined %}
    environment:
      # Validate ES256 (current) + HS256 (legacy + agent tokens) via JWKS.
      PGRST_JWT_SECRET: ${JWT_JWKS}
      PGRST_APP_SETTINGS_JWT_SECRET: ${JWT_JWKS}
{% endif %}

  realtime:
    cap_drop:
      - ALL
    cap_add:
      - SETUID
      - SETGID
    read_only: true
    tmpfs:
      - /tmp
    # Realtime stays on HS256-only (Joken library doesn't parse JWKS) until
    # upstream supabase-realtime adds JWKS support. Browser clients work
    # around this by calling the mint-realtime-token Edge Function to swap
    # their ES256 user JWT for a short-lived HS256 side-token, then handing
    # it to sb.realtime.setAuth() before .subscribe(). See
    # files/functions/mint-realtime-token/index.ts.

  storage:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
{% if oauth_server_enabled and vault_jwt_jwks is defined %}
    environment:
      PGRST_JWT_SECRET: ${JWT_JWKS}
{% endif %}

  imgproxy:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  meta:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  functions:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    environment:
      # Tenant Edge Function secrets — scoped here so they don't leak to
      # other Supabase services. Source values come from .env (mode 0600).
      GROQ_API_KEY: ${GROQ_API_KEY}
{% if oauth_server_enabled and vault_jwt_jwks is defined %}
      # Runtime validates incoming JWTs (ES256 + HS256) against the JWKS.
      JWT_SECRET: ${JWT_JWKS}
      # Functions that still sign HS256 tokens (e.g. mint-agent-token) read
      # the legacy shared secret from this var. JWT_SECRET is no longer a
      # plain string after the OIDC cutover.
      LEGACY_HS256_SECRET: ${JWT_SECRET}
{% endif %}

  analytics:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp

  vector:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - DAC_READ_SEARCH
    read_only: true
    tmpfs:
      - /tmp
      - /var/lib/vector

  db:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - FOWNER
      - SETUID
      - SETGID
      - DAC_OVERRIDE
    read_only: true
    tmpfs:
      - /tmp
      - /var/run/postgresql
    ports: !reset
      - "127.0.0.1:5432:5432"

  supavisor:
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    ports: !reset
      - "127.0.0.1:6543:6543"

networks:
  frontend:

volumes:
  gatus_data:
  gitea_data:
  pomerium_data:
