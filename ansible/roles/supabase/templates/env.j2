############
# Secrets — generated by Ansible from vault
############

POSTGRES_PASSWORD={{ vault_postgres_password }}
JWT_SECRET={{ vault_jwt_secret }}
ANON_KEY={{ vault_anon_key }}
SERVICE_ROLE_KEY={{ vault_service_role_key }}
{% if vault_jwt_jwks is defined %}
JWT_JWKS={{ vault_jwt_jwks }}
GOTRUE_JWT_KEYS={{ vault_gotrue_jwt_keys }}
GOTRUE_JWT_VALID_METHODS=ES256,HS256
{% endif %}
DASHBOARD_USERNAME={{ vault_dashboard_username }}
DASHBOARD_PASSWORD={{ vault_dashboard_password }}
SECRET_KEY_BASE={{ vault_secret_key_base }}
VAULT_ENC_KEY={{ vault_vault_enc_key }}
PG_META_CRYPTO_KEY={{ vault_pg_meta_crypto_key }}
LOGFLARE_PUBLIC_ACCESS_TOKEN={{ vault_logflare_public_key }}
LOGFLARE_PRIVATE_ACCESS_TOKEN={{ vault_logflare_private_key }}
S3_PROTOCOL_ACCESS_KEY_ID={{ vault_s3_access_key_id }}
S3_PROTOCOL_ACCESS_KEY_SECRET={{ vault_s3_access_key_secret }}

############
# URLs
############

SUPABASE_PUBLIC_URL=https://{{ supabase_api_domain }}
API_EXTERNAL_URL=https://{{ supabase_api_domain }}
SITE_URL=https://{{ auth_domain }}
ADDITIONAL_REDIRECT_URLS={% for t in tenants %}https://{{ t.domain }}{% if not loop.last %},{% endif %}{% endfor %}


############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Supavisor
############

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=platform
POOLER_DB_POOL_SIZE=5

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=JMR Platform
STUDIO_DEFAULT_PROJECT=Platform

############
# Auth
############

JWT_EXPIRY=3600
DISABLE_SIGNUP=false
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@{{ primary_domain }}
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=JMR Platform
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=false
GOTRUE_SMS_PROVIDER=twilio_verify
GOTRUE_SMS_TWILIO_VERIFY_ACCOUNT_SID={{ vault_twilio_account_sid }}
GOTRUE_SMS_TWILIO_VERIFY_AUTH_TOKEN={{ vault_twilio_auth_token }}
GOTRUE_SMS_TWILIO_VERIFY_MESSAGE_SERVICE_SID={{ vault_twilio_verify_service_sid }}

############
# Social providers
############

{% if vault_google_oauth_client_id is defined %}
GOTRUE_EXTERNAL_GOOGLE_ENABLED=true
GOTRUE_EXTERNAL_GOOGLE_CLIENT_ID={{ vault_google_oauth_client_id }}
GOTRUE_EXTERNAL_GOOGLE_SECRET={{ vault_google_oauth_secret }}
GOTRUE_EXTERNAL_GOOGLE_REDIRECT_URI=https://{{ supabase_api_domain }}/auth/v1/callback
{% endif %}

{% if vault_github_oauth_client_id is defined %}
GOTRUE_EXTERNAL_GITHUB_ENABLED=true
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID={{ vault_github_oauth_client_id }}
GOTRUE_EXTERNAL_GITHUB_SECRET={{ vault_github_oauth_secret }}
GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI=https://{{ supabase_api_domain }}/auth/v1/callback
{% endif %}

############
# OAuth 2.1 Server
############

{% if vault_gotrue_jwt_keys is defined %}
GOTRUE_OAUTH_SERVER_ENABLED=true
GOTRUE_OAUTH_SERVER_AUTHORIZATION_PATH=/authorize
GOTRUE_OAUTH_SERVER_AUTHORIZATION_TTL=10m
GOTRUE_OAUTH_SERVER_DEFAULT_SCOPE=openid email
GOTRUE_OAUTH_SERVER_ALLOW_DYNAMIC_REGISTRATION=false
{% endif %}

############
# Storage
############

GLOBAL_S3_BUCKET=stub
REGION=us-east-1
STORAGE_TENANT_ID=platform

############
# Functions
############

FUNCTIONS_VERIFY_JWT=true

############
# API (PostgREST)
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Analytics
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock

############
# API gateway (Kong)
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# imgproxy
############

IMGPROXY_AUTO_WEBP=true
